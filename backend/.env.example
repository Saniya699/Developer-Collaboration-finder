SECRET_KEY=dev-secret-change-me
JWT_SECRET_KEY=dev-jwt-secret-change-me

# SQLite by default. Example alternative:
# DATABASE_URL=sqlite:///./dev.sqlite3
DATABASE_URL=sqlite:///dev_developer_collaboration_finder.sqlite3

# Optional host/port for run.py
HOST=127.0.0.1
PORT=5000

# Token lifetimes (minutes)
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_MINUTES=1440

# Optional file upload limit (bytes)
RESUME_MAX_FILE_BYTES=8388608

